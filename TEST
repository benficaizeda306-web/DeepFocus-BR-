# ══════════════════════════════════════════════════════════════════════════════
# The C++ module is responsible for:
#   • Storing per-block Epartial history (rolling window of 512 values)
#   • Computing EMA-based Alpha (P25) / Beta (P75) thresholds
#   • Making routing decisions: SKIP(0) / LOW_PRECISION(1) / FULL_PRECISION(2)
#   • Bernoulli ergodicity: randomly forces FULL to prevent permanent stagnation
#   • Tracking routing counts for FLOPs accounting
# Gradient sampling and stochastic rounding are done in PyTorch/GPU for speed.

_CPP_SOURCE = r"""
#include <pybind11/pybind11.h>
#include <pybind11/stl.h>
#include <vector>
#include <cmath>
#include <algorithm>
#include <random>
#include <numeric>
#include <stdexcept>
#include <string>

namespace py = pybind11;

struct BlockState {
    // Rolling history of Epartial values
    std::vector<float> history;
    static constexpr size_t MAX_HIST = 512;

    // EMA thresholds
    float alpha = 0.0f;   // lower threshold (P25 EMA)
    float beta  = 1.0f;   // upper threshold (P75 EMA)
    bool  initialized = false;

    // Routing counters (reset per epoch)
    long long cnt_skip = 0, cnt_low = 0, cnt_full = 0, cnt_total = 0;
    // Cumulative counters (never reset)
    long long cum_skip = 0, cum_low = 0, cum_full = 0, cum_total = 0;

    void push(float e) {
        history.push_back(e);
        if (history.size() > MAX_HIST)
            history.erase(history.begin());
    }

    void update_thresholds(float ema_alpha) {
        if (history.size() < 8) return;
        std::vector<float> s(history);
        std::sort(s.begin(), s.end());
        size_t n = s.size();
        float p25 = s[n / 4];
        float p75 = s[3 * n / 4];
        if (!initialized) {
            alpha = p25; beta = p75;
            initialized = true;
        } else {
            alpha = ema_alpha * p25 + (1.0f - ema_alpha) * alpha;
            beta  = ema_alpha * p75 + (1.0f - ema_alpha) * beta;
        }
        // Guard: alpha < beta always
        if (alpha >= beta) beta = alpha + 1e-6f;
    }
};

class DeepFocusRouter {
public:
    DeepFocusRouter(int n_blocks,
                    float ema_alpha   = 0.05f,
                    float bernoulli_p = 0.01f)
        : n_blocks_(n_blocks),
          ema_alpha_(ema_alpha),
          bern_p_(bernoulli_p),
          rng_(std::random_device{}()),
          bern_(bernoulli_p),
          uni_(0.0f, 1.0f)
    {
        blocks_.resize(n_blocks_);
    }

    // Called once per block per backward step with the scalar Epartial.
    // Returns routing decision: 0=SKIP, 1=LOW, 2=FULL
    int update_and_route(float epartial, int block_id) {
        _check(block_id);
        auto& b = blocks_[block_id];

        b.push(epartial);
        b.update_thresholds(ema_alpha_);

        b.cnt_total++; b.cum_total++;

        // Bernoulli ergodicity: forced FULL regardless of Epartial
        if (bern_(rng_)) {
            b.cnt_full++; b.cum_full++;
            return 2;
        }

        if (!b.initialized || epartial > b.beta) {
            b.cnt_full++; b.cum_full++;
            return 2;  // FULL
        } else if (epartial < b.alpha) {
            b.cnt_skip++; b.cum_skip++;
            return 0;  // SKIP
        } else {
            b.cnt_low++;  b.cum_low++;
            return 1;  // LOW
        }
    }

    // Reset per-epoch counters (call at start of each epoch)
    void reset_epoch() {
        for (auto& b : blocks_)
            b.cnt_skip = b.cnt_low = b.cnt_full = b.cnt_total = 0;
    }

    // Aggregate statistics across all blocks
    py::dict get_stats(bool cumulative = false) const {
        long long tot_s = 0, tot_l = 0, tot_f = 0, tot_t = 0;
        std::vector<float> alphas, betas;

        for (auto& b : blocks_) {
            long long s = cumulative ? b.cum_skip  : b.cnt_skip;
            long long l = cumulative ? b.cum_low   : b.cnt_low;
            long long f = cumulative ? b.cum_full  : b.cnt_full;
            long long t = cumulative ? b.cum_total : b.cnt_total;
            tot_s += s; tot_l += l; tot_f += f; tot_t += t;
            if (b.initialized) {
                alphas.push_back(b.alpha);
                betas.push_back(b.beta);
            }
        }

        float skip_r = tot_t > 0 ? float(tot_s) / tot_t : 0.0f;
        float low_r  = tot_t > 0 ? float(tot_l) / tot_t : 0.0f;
        float full_r = tot_t > 0 ? float(tot_f) / tot_t : 0.0f;
        // Theoretical FLOPs fraction actually used (SKIP=0, LOW=0.5, FULL=1.0)
        float flops_used     = skip_r * 0.0f + low_r * 0.5f + full_r * 1.0f;
        float flops_reduction = 1.0f - flops_used;

        auto mean_vec = [](const std::vector<float>& v) {
            if (v.empty()) return 0.0f;
            return std::accumulate(v.begin(), v.end(), 0.0f) / v.size();
        };

        py::dict d;
        d["skip_rate"]       = skip_r;
        d["low_rate"]        = low_r;
        d["full_rate"]       = full_r;
        d["flops_used"]      = flops_used;
        d["flops_reduction"] = flops_reduction;
        d["alpha_mean"]      = mean_vec(alphas);
        d["beta_mean"]       = mean_vec(betas);
        d["total_decisions"] = tot_t;
        return d;
    }

    // Per-block diagnostic (for detailed logs)
    py::list get_block_stats() const {
        py::list out;
        for (int i = 0; i < n_blocks_; i++) {
            auto& b = blocks_[i];
            py::dict d;
            d["block_id"] = i;
            d["alpha"]    = b.alpha;
            d["beta"]     = b.beta;
            long long t = b.cnt_total;
            d["skip_pct"] = t > 0 ? 100.0f * b.cnt_skip / t : 0.0f;
            d["low_pct"]  = t > 0 ? 100.0f * b.cnt_low  / t : 0.0f;
            d["full_pct"] = t > 0 ? 100.0f * b.cnt_full / t : 0.0f;
            out.append(d);
        }
        return out;
    }

    int n_blocks() const { return n_blocks_; }

private:
    void _check(int id) const {
        if (id < 0 || id >= n_blocks_)
            throw std::out_of_range("block_id=" + std::to_string(id) +
                                    " out of range [0," + std::to_string(n_blocks_) + ")");
    }

    int   n_blocks_;
    float ema_alpha_, bern_p_;
    std::mt19937                        rng_;
    std::bernoulli_distribution         bern_;
    std::uniform_real_distribution<float> uni_;
    std::vector<BlockState>             blocks_;
};

