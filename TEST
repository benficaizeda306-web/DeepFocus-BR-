    else:  # agnews — test split has 7600 rows, plenty of room
        ds, vocab = _get_agnews()
        tr_raw   = [(x["text"], x["label"]) for x in ds["train"]]
        eval_raw = [(x["text"],  x["label"]) for x in ds["test"]]

    # ── Train split ────────────────────────────────────────────────────────────
    tr_idx = rng.sample(range(len(tr_raw)), min(n_train, len(tr_raw)))

    # ── Val / Test split  (robust: never exceed available, never starve either)
    avail = len(eval_raw)
    # Desired totals, capped at what is available
    want_val  = min(n_val,  avail - _MIN_EVAL)   # leave room for test
    want_test = min(n_test, avail - _MIN_EVAL)   # leave room for val
    # If dataset is very small, fall back to 60/40 proportional split
    if want_val <= 0 or want_test <= 0:
        want_val  = max(_MIN_EVAL, int(avail * 0.6))
        want_test = max(_MIN_EVAL, avail - want_val)
    # Final cap: val + test ≤ avail
    total_eval = min(want_val + want_test, avail)
    want_val   = min(want_val,  total_eval - _MIN_EVAL)
    want_test  = total_eval - want_val

    eval_idx = rng.sample(range(avail), total_eval)
    val_idx  = eval_idx[:want_val]
    test_idx = eval_idx[want_val:want_val + want_test]

    def mk(pairs, idx): return [pairs[i][0] for i in idx], [pairs[i][1] for i in idx]

    tr_t,  tr_l  = mk(tr_raw,   tr_idx)
    vl_t,  vl_l  = mk(eval_raw, val_idx)
    te_t,  te_l  = mk(eval_raw, test_idx)

    print(f"   Split sizes → train={len(tr_t):,}  val={len(vl_t):,}  test={len(te_t):,}  "
          f"(eval pool={avail:,})")

    nw = 2
    tr_dl = DataLoader(TextDataset(tr_t, tr_l, vocab), batch_size=batch_size,   shuffle=True,  num_workers=nw, pin_memory=True)
    vl_dl = DataLoader(TextDataset(vl_t, vl_l, vocab), batch_size=batch_size*2, shuffle=False, num_workers=nw, pin_memory=True)
    te_dl = DataLoader(TextDataset(te_t, te_l, vocab), batch_size=batch_size*2, shuffle=False, num_workers=nw, pin_memory=True)
    return tr_dl, vl_dl, te_dl


def make_cifar10_loaders(batch_size: int, seed: int):
    tr_full, te_full = _get_cifar10()
    rng = random.Random(seed)
    all_te = list(range(len(te_full)))
    rng.shuffle(all_te)
    val_idx  = all_te[:2000]
    test_idx = all_te[2000:4000]
    tr_dl  = DataLoader(tr_full,              batch_size=batch_size,   shuffle=True,  num_workers=2, pin_memory=True)
    vl_dl  = DataLoader(Subset(te_full, val_idx),  batch_size=batch_size*2, shuffle=False, num_workers=2, pin_memory=True)
    te_dl  = DataLoader(Subset(te_full, test_idx), batch_size=batch_size*2, shuffle=False, num_workers=2, pin_memory=True)
    return tr_dl, vl_dl, te_dl


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 5 — DEEPFOCUS ROUTING CORE
# ══════════════════════════════════════════════════════════════════════════════

# Target rates for Random DropConnect (from paper's stabilized distribution)
_RAND_SKIP = 0.26
_RAND_LOW  = 0.49
# _RAND_FULL = 0.25   (remainder)

def apply_routing(model: nn.Module,
                  method: str,
                  router,            # dfe.DeepFocusRouter | None
                  ) -> dict:
    """
    Called AFTER loss.backward(), BEFORE optimizer.step().

    For each block:
      1. Sample probe_frac of gradient magnitudes → Epartial (GPU, cheap)
      2. Route via C++ engine (DeepFocus) or randomly (Random baseline)
      3. Apply routing:
         SKIP  → zero all gradients in block  (100% savings)
         LOW   → stochastic FP8 rounding      ( ~50% savings)
         FULL  → no modification              (0% savings)

    Returns per-step routing summary dict.
    """
    if method == "dense":
        return {"skip": 0.0, "low": 0.0, "full": 1.0, "flops_used": 1.0}

    blocks = model.get_blocks()
    decisions = []

    for block_id, block in blocks:
        pgrads = [p.grad for p in block.parameters() if p.grad is not None]
        if not pgrads:
            decisions.append(2)   # treat as FULL if no gradients
            continue

        # ── Epartial (sampled probe on GPU, scalar transferred) ──────────
        epartial = sample_epartial(pgrads)

        # ── Routing decision ──────────────────────────────────────────────
        if method == "deepfocus":
            decision = router.update_and_route(epartial, block_id)
        else:  # random
            r = random.random()
            if r < _RAND_SKIP:
                decision = 0
            elif r < _RAND_SKIP + _RAND_LOW:
                decision = 1
            else:
                decision = 2

        decisions.append(decision)

        # ── Apply routing ─────────────────────────────────────────────────
        if decision == 0:          # SKIP — zero gradients
            for p in block.parameters():
                if p.grad is not None:
                    p.grad.zero_()

        elif decision == 1:        # LOW — stochastic FP8 rounding (on GPU)
            for p in block.parameters():
                if p.grad is not None:
                    p.grad.copy_(stochastic_round_fp8_gpu(p.grad))

        # FULL — leave gradients untouched

    n = len(decisions)
    n_skip = decisions.count(0)
    n_low  = decisions.count(1)
    n_full = decisions.count(2)
    flops_used = (n_full * 1.0 + n_low * 0.5) / n if n > 0 else 1.0

    return {
        "skip":       n_skip / n,
        "low":        n_low  / n,
        "full":       n_full / n,
        "flops_used": flops_used,
    }


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 6 — TRAINING & EVALUATION LOOP
# ══════════════════════════════════════════════════════════════════════════════

@torch.no_grad()
def evaluate(model, loader, criterion, is_text: bool):
    model.eval()
    tot_loss = tot_correct = tot_n = 0
    for batch in loader:
        if is_text:
            ids, mask, lbl = [x.to(DEVICE) for x in batch]
            logits = model(ids, mask)
        else:
            imgs, lbl = batch[0].to(DEVICE), batch[1].to(DEVICE)
            logits = model(imgs)
        tot_loss    += criterion(logits, lbl).item() * lbl.size(0)
        tot_correct += (logits.argmax(1) == lbl).sum().item()
        tot_n       += lbl.size(0)
    model.train()
    if tot_n == 0:
        raise RuntimeError(
            "evaluate() called on an empty DataLoader — the split produced 0 samples. "
            "Check n_val/n_test vs. dataset size."
        )
    return tot_loss / tot_n, tot_correct / tot_n


def train_one_run(model, train_dl, val_dl, test_dl,
                  method: str, router,
                  epochs: int, lr: float,
                  is_text: bool, label: str) -> dict:
    """
    Full training run. Returns per-epoch log + final test metrics.
    """
    criterion = nn.CrossEntropyLoss()
    optimizer = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-2)
    scheduler = CosineAnnealingLR(optimizer, T_max=epochs, eta_min=lr * 0.01)

    if router is not None:
        router.reset_epoch()

    LOG_FREQ    = max(1, len(train_dl) // 4)   # 4 intra-epoch log points
    run_start   = time.time()
    best_val_acc = 0.0
    epoch_logs: list[dict] = []

    # Running FLOPs accumulators
    cum_flops_used = 0.0      # sum of per-step flops_used
    cum_steps      = 0

    for epoch in range(1, epochs + 1):
        ep_start = time.time()
        model.train()
        if router: router.reset_epoch()

        ep_loss = ep_correct = ep_n = 0
        ep_skip = ep_low = ep_full = ep_flops = 0.0
        ep_gnorm = 0.0
        step_cnt = 0

        for step, batch in enumerate(train_dl):
            if is_text:
                ids, mask, lbl = [x.to(DEVICE) for x in batch]
                logits = model(ids, mask)
            else:
                imgs, lbl = batch[0].to(DEVICE), batch[1].to(DEVICE)
                logits = model(imgs)

            loss = criterion(logits, lbl)
            optimizer.zero_grad()
            loss.backward()

            # ── DeepFocus routing (modifies .grad in-place) ───────────────
            routing = apply_routing(model, method, router)

            # ── Gradient clipping (after routing) ─────────────────────────
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
            gnorm = compute_grad_norm(model)

            optimizer.step()

            # ── Accumulate metrics ────────────────────────────────────────
            bs = lbl.size(0)
            ep_loss    += loss.item() * bs
            ep_correct += (logits.argmax(1) == lbl).sum().item()
            ep_n       += bs
            ep_skip    += routing["skip"]
            ep_low     += routing["low"]
            ep_full    += routing["full"]
            ep_flops   += routing["flops_used"]
            ep_gnorm   += gnorm
            step_cnt   += 1
            cum_flops_used += routing["flops_used"]
            cum_steps      += 1

            # ── Intra-epoch step log ──────────────────────────────────────
            if (step + 1) % LOG_FREQ == 0 or step == len(train_dl) - 1:
                sc = step_cnt
                _skip = ep_skip / sc; _low = ep_low / sc; _full = ep_full / sc
                _fr   = 1.0 - ep_flops / sc
                _mem  = torch.cuda.memory_reserved(0) / 1e9 if torch.cuda.is_available() else 0.0
                print(
                    f"  E{epoch:02d} │ step {step+1:04d}/{len(train_dl):04d} │ "
                    f"loss {ep_loss/ep_n:.4f}  acc {ep_correct/ep_n:.4f} │ "
                    f"Skip {_skip:.0%}  Low {_low:.0%}  Full {_full:.0%} │ "
                    f"FLOPs↓ {_fr:.2%}  ‖∇‖ {gnorm:.3f}  GPU {_mem:.1f}GB"
                )

        # ── End-of-epoch ──────────────────────────────────────────────────
        scheduler.step()
        val_loss, val_acc = evaluate(model, val_dl, criterion, is_text)
        best_val_acc = max(best_val_acc, val_acc)
        ep_time = time.time() - ep_start

        s = step_cnt
        avg = lambda x: x / s
        ep_dict = dict(
            epoch       = epoch,
            train_loss  = ep_loss / ep_n,
            train_acc   = ep_correct / ep_n,
            val_loss    = val_loss,
            val_acc     = val_acc,
            skip_rate   = avg(ep_skip),
            low_rate    = avg(ep_low),
            full_rate   = avg(ep_full),
            flops_reduction = 1.0 - avg(ep_flops),
            grad_norm   = avg(ep_gnorm),
            lr          = scheduler.get_last_lr()[0],
            epoch_time_s = ep_time,
        )
        if router:
            ep_dict["router_stats"]      = dict(router.get_stats(cumulative=False))
            ep_dict["router_block_stats"] = [dict(b) for b in router.get_block_stats()]
        epoch_logs.append(ep_dict)

        # Per-block diagnostic (DeepFocus only)
        blk_info = ""
        if router and method == "deepfocus":
            bstats = [dict(b) for b in router.get_block_stats()]
            blk_info = "  │ Per-block: " + "  ".join(
                f"B{b['block_id']}[α={b['alpha']:.3f} β={b['beta']:.3f} "
                f"S{b['skip_pct']:.0f}%/L{b['low_pct']:.0f}%/F{b['full_pct']:.0f}%]"
                for b in bstats
            )

        print(f"\n  ┌{'─'*66}┐")
        print(f"  │  EPOCH {epoch:02d}/{epochs}  ─  {method.upper()}  ─  {label}")
        print(f"  │  Train  loss={ep_dict['train_loss']:.4f}  acc={ep_dict['train_acc']:.4f}")
        print(f"  │  Val    loss={val_loss:.4f}  acc={val_acc:.4f}  (best={best_val_acc:.4f})")
        print(f"  │  Route  Skip={ep_dict['skip_rate']:.2%}  Low={ep_dict['low_rate']:.2%}  Full={ep_dict['full_rate']:.2%}")
        print(f"  │  FLOPs↓ {ep_dict['flops_reduction']:.2%} (theoretical)  ‖∇‖={ep_dict['grad_norm']:.4f}  LR={ep_dict['lr']:.2e}  t={ep_time:.1f}s")
        if blk_info: print(blk_info)
        print(f"  └{'─'*66}┘\n")

    # ── Final test ────────────────────────────────────────────────────────────
    test_loss, test_acc = evaluate(model, test_dl, criterion, is_text)
    run_time = time.time() - run_start
    overall_flops_red = 1.0 - (cum_flops_used / cum_steps) if cum_steps > 0 else 0.0
    cum_router_stats  = dict(router.get_stats(cumulative=True)) if router else {}

    print(f"\n  ╔══════════════════════════════════════════════════════════╗")
    print(f"  ║  TEST RESULT  │  acc={test_acc:.4f}  loss={test_loss:.4f}")
    print(f"  ║  Run time     │  {run_time/60:.2f} min")
    print(f"  ║  FLOPs↓ (overall) │  {overall_flops_red:.2%}")
    print(f"  ╚══════════════════════════════════════════════════════════╝\n")

    return dict(
        test_acc           = test_acc,
        test_loss          = test_loss,
        best_val_acc       = best_val_acc,
        run_time_min       = run_time / 60,
        overall_flops_red  = overall_flops_red,
        epoch_logs         = epoch_logs,
        cum_router_stats   = cum_router_stats,
    )


