              f"FLOPs used={rs.get('flops_used',1):.2%}  "
              f"α={rs.get('alpha_mean',0):.4f}  β={rs.get('beta_mean',1):.4f}  "
              f"decisions={rs.get('total_decisions',0):,}")

# ── Save JSON ─────────────────────────────────────────────────────────────────
def _serial(obj):
    if isinstance(obj, (np.floating, float)): return float(obj)
    if isinstance(obj, (np.integer, int)):    return int(obj)
    if isinstance(obj, np.ndarray):           return obj.tolist()
    if isinstance(obj, dict):  return {k: _serial(v) for k, v in obj.items()}
    if isinstance(obj, list):  return [_serial(v) for v in obj]
    if isinstance(obj, bool):  return obj
    return obj

_out = dict(
    stats          = _serial(STATS),
    total_time_min = _total_time / 60,
    seeds          = SEEDS,
    methods        = METHODS,
    experiments    = {k: {j: v for j, v in cfg.items() if not callable(v)}
                      for k, cfg in EXPS.items()},
)
_json_path = "/tmp/deepfocus_results.json"
with open(_json_path, "w") as _f:
    json.dump(_out, _f, indent=2)

print(f"\n\n  Full results → {_json_path}")
