def bootstrap_ci(vals: list, n_boot: int = 1000, ci: float = 0.95):
    a = np.array(vals, dtype=float)
    boots = [np.mean(np.random.choice(a, len(a), replace=True)) for _ in range(n_boot)]
    lo = np.percentile(boots, (1 - ci) / 2 * 100)
    hi = np.percentile(boots, (1 + ci) / 2 * 100)
    return lo, hi

def cohens_d(a, b):
    a, b = np.array(a, float), np.array(b, float)
    s = math.sqrt((a.std(ddof=1)**2 + b.std(ddof=1)**2) / 2)
    return (a.mean() - b.mean()) / s if s > 1e-12 else 0.0

