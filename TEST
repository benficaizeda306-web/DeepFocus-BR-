PROBE_FRAC = 0.10   # fraction of gradient elements sampled for Epartial

def sample_epartial(param_grads: list, probe_frac: float = PROBE_FRAC) -> float:
    """
    Fast GPU-side stochastic probe: randomly sample probe_frac of all gradient
    values across the block, compute L2 norm of the sample.
    Returns a scalar float (cheap: only k floats transferred to CPU).
    """
    flat = torch.cat([g.detach().reshape(-1) for g in param_grads if g is not None])
    if flat.numel() == 0:
        return 0.0
    k = max(16, int(flat.numel() * probe_frac))
    k = min(k, flat.numel())
    idx = torch.randint(0, flat.numel(), (k,), device=flat.device)
    sample = flat[idx]
    return (sample.norm() / math.sqrt(k)).item()


@torch.no_grad()
def stochastic_round_fp8_gpu(grad: torch.Tensor, scale: float = 448.0) -> torch.Tensor:
    """
    Simulates FP8 E4M3 quantization via stochastic rounding, fully on GPU.
    Preserves gradient expectation: E[round(x)] = x.
    Cost: ~50% of FP32 backward (memory bandwidth reduction).
    """
    g = grad.float().clamp(-scale, scale)
    step = 2.0 * scale / 255.0
    q = (g / step).floor()
    frac = g / step - q
    noise = torch.rand_like(g)
    q = q + (noise < frac).to(g.dtype)
    return (q * step).to(grad.dtype)


def compute_grad_norm(model: nn.Module) -> float:
    """Global gradient L2 norm across all parameters."""
    total = 0.0
    for p in model.parameters():
        if p.grad is not None:
            total += p.grad.detach().norm().item() ** 2
    return math.sqrt(total)


